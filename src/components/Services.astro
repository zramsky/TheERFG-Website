---
import LucideIcon from './LucideIcon';

const services = [
  {
    icon: 'FileText' as const,
    title: 'Accounts Payable',
    description:
      'Invoice processing, vendor management, and payment optimization',
  },
  {
    icon: 'DollarSign' as const,
    title: 'Accounts Receivable',
    description:
      'Client billing, collections, and cash flow acceleration',
  },
  {
    icon: 'Users' as const,
    title: 'Payroll Management',
    description:
      'End-to-end payroll processing, tax filing, and compliance',
  },
  {
    icon: 'BookOpen' as const,
    title: 'Accounting & GL Management',
    description:
      'Journal entries, reconciliations, and financial record-keeping',
  },
  {
    icon: 'Shield' as const,
    title: 'Tax Planning & Compliance',
    description:
      'Strategic tax planning and regulatory compliance management',
  },
  {
    icon: 'BarChart3' as const,
    title: 'Financial Reporting',
    description:
      'Monthly statements, KPI tracking, and strategic insights',
  },
  {
    icon: 'Droplets' as const,
    title: 'Cash Flow Support',
    description:
      'Forecasting, liquidity management, and financial optimization',
  },
  {
    icon: 'Settings' as const,
    title: 'Financial Process Optimization',
    description:
      'System implementation, workflow automation, and efficiency gains',
  },
  {
    icon: 'Package' as const,
    title: 'Custom Finance Support',
    description:
      'Tailored packages designed for your unique business needs',
  },
];
---

<section class="pt-8 pb-20 px-6 bg-[#F4F2ED]" id="services">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.5fr] gap-14 items-start">
      <!-- Left side: description -->
      <div data-anim="fade-left">
        <p
          class="uppercase text-xs font-bold tracking-[3px] text-accent mb-3"
        >
          Services
        </p>
        <h2
          class="text-[1.85rem] md:text-[3rem] font-bold text-[#1A1F2E] mb-4 leading-tight tracking-tight font-serif"
        >
          Your Outsourced Financial Operations
        </h2>
        <div class="w-16 h-[3px] bg-accent mb-6 divider-animate"></div>
        <p
          class="text-base text-[#5A6070] leading-relaxed mb-4"
        >
          We operate as your finance department — managing the full cycle of your financial operations from transaction processing to strategic reporting.
        </p>
        <p
          class="text-base text-[#5A6070] leading-relaxed mb-4"
        >
          Every function listed here runs under one team with one system of accountability. No handoffs between vendors, no gaps in coverage.
        </p>
        <p
          class="text-base text-[#5A6070] leading-relaxed mb-8"
        >
          Each engagement is scoped to your business model — single location or multi-site, simple or complex. The structure scales with you.
        </p>
        <a
          href="#contact"
          class="inline-block px-8 py-3.5 bg-[#1A1F2E] text-white rounded-lg font-semibold text-[0.95rem] border-2 border-[#1A1F2E] hover:bg-[#2A3040] hover:border-[#2A3040] hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(26,31,46,0.2)] transition-all duration-250"
        >
          Discuss Your Needs
        </a>
      </div>

      <!-- Right side: service cards grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" data-stagger>
        {
          services.map((service) => (
            <div
              class="bg-card-bg border border-card-border rounded-xl p-6 transition-all duration-300 hover:border-accent/50 hover:-translate-y-1 hover:shadow-[0_4px_20px_rgba(26,31,46,0.08)] shadow-[0_1px_3px_rgba(26,31,46,0.04)] card-glow"
              data-anim="fade-up"
            >
              <div class="w-10 h-10 bg-accent/15 rounded-[10px] flex items-center justify-center mb-3">
                <LucideIcon
                  name={service.icon}
                  size={20}
                  className="text-accent"
                />
              </div>
              <h3 class="text-base font-bold text-[#1A1F2E] mb-2 font-serif">
                {service.title}
              </h3>
              <p class="text-[0.95rem] text-[#5A6070] leading-relaxed">
                {service.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
