---
const services = [
  {
    title: 'Accounts Payable',
    description:
      'Invoice processing, vendor management, and payment optimization',
  },
  {
    title: 'Accounts Receivable',
    description:
      'Client billing, collections, and cash flow acceleration',
  },
  {
    title: 'Payroll Management',
    description:
      'End-to-end payroll processing, tax filing, and compliance',
  },
  {
    title: 'Accounting & GL Management',
    description:
      'Journal entries, reconciliations, and financial record-keeping',
  },
  {
    title: 'Tax Planning & Compliance',
    description:
      'Strategic tax planning and regulatory compliance management',
  },
  {
    title: 'Financial Reporting',
    description:
      'Monthly statements, KPI tracking, and strategic insights',
  },
  {
    title: 'Cash Flow Support',
    description:
      'Forecasting, liquidity management, and financial optimization',
  },
  {
    title: 'Financial Process Optimization',
    description:
      'System implementation, workflow automation, and efficiency gains',
  },
  {
    title: 'Custom Finance Support',
    description:
      'Tailored packages designed for your unique business needs',
  },
];
---

<section class="py-24 px-6 relative overflow-hidden" id="services">
  <!-- Dark blue gradient background -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(160deg, #122840 0%, #1B3A5C 50%, #2A5080 100%);"
  >
  </div>
  <!-- Decorative glow -->
  <div
    class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full"
    style="background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, transparent 70%);"
  >
  </div>

  <div class="max-w-[1200px] mx-auto relative z-10">
    <div class="text-center mb-14">
      <p
        class="uppercase text-xs font-bold tracking-[3px] text-accent-subtle mb-3"
      >
        Services
      </p>
      <h2
        class="text-[1.85rem] md:text-[2.5rem] font-extrabold text-white mb-4 leading-tight tracking-tight"
      >
        Your Outsourced Financial Operations
      </h2>
      <p
        class="text-lg text-white/60 max-w-[640px] mx-auto leading-relaxed"
      >
        We act as your full outsourced finance department -- managing every
        aspect of your financial operations with precision and care. Every
        service is tailored to your business model, whether you're managing a
        single location or running a complex multi-site operation.
      </p>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12"
    >
      {
        services.map((service) => (
          <div class="bg-white/[0.06] border border-white/10 rounded-xl p-7 backdrop-blur-sm transition-all duration-250 hover:bg-white/10 hover:border-white/20 hover:-translate-y-0.5">
            <h3 class="text-base font-bold text-white mb-2">
              {service.title}
            </h3>
            <p class="text-sm text-white/55 leading-relaxed">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>

    <div class="text-center">
      <a
        href="#contact"
        class="inline-block px-8 py-3.5 bg-white text-primary rounded-lg font-semibold text-[0.95rem] border-2 border-white hover:bg-slate-100 hover:border-slate-100 hover:-translate-y-px transition-all duration-250"
      >
        Discuss Your Needs
      </a>
    </div>
  </div>
</section>
