---
const services = [
  {
    title: 'Accounts Payable',
    description:
      'Invoice processing, vendor management, and payment optimization',
  },
  {
    title: 'Accounts Receivable',
    description:
      'Client billing, collections, and cash flow acceleration',
  },
  {
    title: 'Payroll Management',
    description:
      'End-to-end payroll processing, tax filing, and compliance',
  },
  {
    title: 'Accounting & GL Management',
    description:
      'Journal entries, reconciliations, and financial record-keeping',
  },
  {
    title: 'Tax Planning & Compliance',
    description:
      'Strategic tax planning and regulatory compliance management',
  },
  {
    title: 'Financial Reporting',
    description:
      'Monthly statements, KPI tracking, and strategic insights',
  },
  {
    title: 'Cash Flow Support',
    description:
      'Forecasting, liquidity management, and financial optimization',
  },
  {
    title: 'Financial Process Optimization',
    description:
      'System implementation, workflow automation, and efficiency gains',
  },
  {
    title: 'Custom Finance Support',
    description:
      'Tailored packages designed for your unique business needs',
  },
];
---

<section class="py-24 px-6 bg-[#1a1a1a]" id="services">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.5fr] gap-14 items-start">
      <!-- Left side: description -->
      <div>
        <p
          class="uppercase text-xs font-bold tracking-[3px] text-accent mb-3"
        >
          Services
        </p>
        <h2
          class="text-[1.85rem] md:text-[2.5rem] font-bold text-white mb-4 leading-tight tracking-tight font-serif"
        >
          Your Outsourced Financial Operations
        </h2>
        <div class="w-16 h-[3px] bg-accent mb-6"></div>
        <p
          class="text-base text-white/60 leading-relaxed mb-8"
        >
          We act as your full outsourced finance department -- managing every
          aspect of your financial operations with precision and care. Every
          service is tailored to your business model, whether you're managing a
          single location or running a complex multi-site operation.
        </p>
        <a
          href="#contact"
          class="inline-block px-8 py-3.5 bg-accent text-white rounded-lg font-semibold text-[0.95rem] border-2 border-accent hover:bg-accent-hover hover:border-accent-hover hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(200,117,51,0.35)] transition-all duration-250"
        >
          Discuss Your Needs
        </a>
      </div>

      <!-- Right side: service cards grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          services.map((service) => (
            <div class="bg-card-bg border border-card-border rounded-xl p-6 transition-all duration-250 hover:border-accent/30 hover:-translate-y-0.5">
              <h3 class="text-base font-bold text-white mb-2 font-serif">
                {service.title}
              </h3>
              <p class="text-sm text-white/50 leading-relaxed">
                {service.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
