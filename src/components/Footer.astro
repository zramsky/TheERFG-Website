<footer class="bg-[#111111] text-white pt-16 pb-8 px-6">
  <div class="max-w-[1200px] mx-auto">
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1.5fr] gap-10 mb-10"
    >
      <!-- Brand - Text-based logo treatment -->
      <div>
        <a href="#" class="inline-block mb-1">
          <span class="block text-2xl font-bold text-white font-serif">Engine Room</span>
          <span class="block text-xs font-bold uppercase tracking-[3px] text-accent">Financial Group</span>
        </a>
        <p class="text-white/50 text-sm mt-3 leading-relaxed">
          The financial backbone for service-based businesses.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4
          class="text-xs font-bold uppercase tracking-[2px] text-white/40 mb-4"
        >
          Services
        </h4>
        <ul class="space-y-3">
          <li>
            <a
              href="#services"
              class="text-sm text-white/50 hover:text-accent transition-colors"
