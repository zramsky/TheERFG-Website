      <!-- Connect -->
      <div>
        <h4
          class="text-xs font-bold uppercase tracking-[2px] text-white/40 mb-4"
        >
          Connect
        </h4>
        <ul class="space-y-3">
          <li>
            <a
              href="tel:6464506051"
              class="text-sm text-white/50 hover:text-accent transition-colors"
              >646-450-6051</a
            >
          </li>
          <li>
            <a
              href="mailto:contact@TheERFG.com"
              class="text-sm text-white/50 hover:text-accent transition-colors"
              >contact@TheERFG.com</a
            >
          </li>
          <li class="text-sm text-white/50">
            456A Central Ave Suite 115, Cedarthurst, NY 11516
          </li>
          <li class="pt-2">
            <a
              href="#contact"
              class="inline-block px-6 py-2.5 bg-accent text-white rounded-lg font-semibold text-[0.85rem] border-2 border-accent hover:bg-accent-hover hover:border-accent-hover hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(200,117,51,0.35)] transition-all duration-250"
