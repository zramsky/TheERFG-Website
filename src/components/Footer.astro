            >
          </li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4
          class="text-xs font-bold uppercase tracking-[2px] text-white/40 mb-4"
        >
          Company
        </h4>
        <ul class="space-y-3">
          <li>
            <a
              href="#industries"
              class="text-sm text-white/50 hover:text-accent transition-colors"
              >Who We Serve</a
            >
          </li>
          <li>
            <a
              href="#methodology"
              class="text-sm text-white/50 hover:text-accent transition-colors"
              >How We Work</a
