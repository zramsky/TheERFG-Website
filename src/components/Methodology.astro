---
const steps = [
  {
    number: 1,
    title: 'Assess',
    description:
      'We dive deep into your current financial operations, identify pain points, understand your systems, and develop a comprehensive roadmap for improvement. We listen\u2014your business is unique.',
  },
  {
    number: 2,
    title: 'Build',
    description:
      'We implement systems, integrate with your tools, and establish processes that scale with your business. Training and transition planning ensure a smooth handoff.',
  },
  {
    number: 3,
    title: 'Run',
    description:
      'We take over your day-to-day financial operations with precision. Accounts payable, payroll, reconciliations, reporting\u2014everything runs smoothly while you focus on your core business.',
  },
  {
    number: 4,
    title: 'Report & Optimize',
    description:
      'Regular financial reports, strategic insights, and continuous optimization. We\u2019re your partner in understanding your numbers and making better business decisions.',
  },
];
---

<section class="py-24 px-6 bg-off-white" id="methodology">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-14">
      <p class="uppercase text-xs font-bold tracking-[3px] text-accent mb-3">
        How We Work
      </p>
      <h2
        class="text-[1.85rem] md:text-[2.5rem] font-extrabold text-slate-900 mb-4 leading-tight tracking-tight"
      >
        Your Financial Operating System
      </h2>
      <p class="text-lg text-slate-400 max-w-[640px] mx-auto leading-relaxed">
        A proven four-step process to transform your financial operations from a
        source of stress into a strategic advantage.
      </p>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12 relative"
    >
      <!-- Connecting line (hidden on mobile) -->
      <div
        class="hidden lg:block absolute top-7 left-[15%] right-[15%] h-0.5 bg-slate-200 z-0"
      >
      </div>

      {
        steps.map((step) => (
          <div class="text-center px-4 py-6 relative z-10">
            <div class="w-14 h-14 bg-accent text-white rounded-full flex items-center justify-center text-xl font-extrabold mx-auto mb-5 shadow-[0_4px_12px_rgba(59,130,246,0.3)]">
              {step.number}
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2.5">
              {step.title}
            </h3>
            <p class="text-sm text-slate-400 leading-relaxed">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>

    <div class="text-center">
      <a
        href="#contact"
        class="inline-block px-8 py-3.5 bg-accent text-white rounded-lg font-semibold text-[0.95rem] border-2 border-accent hover:bg-accent-hover hover:border-accent-hover hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(59,130,246,0.35)] transition-all duration-250"
      >
        Start Your Engine
      </a>
    </div>
  </div>
</section>
