---
const steps = [
  {
    number: 1,
    title: 'Assess',
    description:
      'We audit your current financial operations — systems, workflows, staffing, and reporting. We identify what is working, what is not, and where the gaps are. The output is a clear scope of work.',
  },
  {
    number: 2,
    title: 'Build',
    description:
      'We configure systems, integrate with your existing tools, and build the processes that will run day-to-day. Transition planning ensures nothing falls through during handoff.',
  },
  {
    number: 3,
    title: 'Run',
    description:
      'We execute your day-to-day financial operations. AP, payroll, reconciliations, reporting — all running on schedule, every period, with full documentation.',
  },
  {
    number: 4,
    title: 'Report & Optimize',
    description:
      'Monthly financial packages, performance metrics, and process reviews. We surface what matters and recommend adjustments as your business evolves.',
  },
];
---

<section class="py-20 px-6 bg-page-bg border-t border-white/[0.05]" id="methodology">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-14">
      <p
        class="uppercase text-xs font-bold tracking-[3px] text-accent mb-3"
        data-anim="fade-up"
      >
        How We Work
      </p>
      <h2
        class="text-[1.85rem] md:text-[3rem] font-bold text-white mb-4 leading-tight tracking-tight font-serif"
        data-anim="fade-up"
        style="transition-delay: 100ms"
      >
        Your Financial Operating System
      </h2>
      <div class="w-16 h-[3px] bg-accent mx-auto mb-4 divider-animate"></div>
      <p
        class="text-xl text-white/60 max-w-[640px] mx-auto leading-relaxed"
        data-anim="fade-up"
        style="transition-delay: 200ms"
      >
        A structured engagement model designed to get your financial operations running cleanly and keep them that way.
      </p>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12 relative"
    >
      <!-- Connecting line (hidden on mobile) -->
      <div
        class="hidden lg:block absolute top-7 left-[15%] right-[15%] h-0.5 bg-accent/30 z-0 connecting-line"
      >
      </div>

      {
        steps.map((step, i) => (
          <div class="text-center px-4 py-6 relative z-10" data-anim="fade-up" style={`transition-delay: ${i * 150}ms`}>
            <div
              class="w-14 h-14 bg-accent text-white rounded-full flex items-center justify-center text-xl font-extrabold mx-auto mb-5 shadow-[0_4px_12px_rgba(200,117,51,0.3)] font-sans step-number"
              style={`animation-delay: ${i * 200 + 300}ms`}
            >
              {step.number}
            </div>
            <h3 class="text-lg font-bold text-white mb-2.5 font-serif">
              {step.title}
            </h3>
            <p class="text-[0.95rem] text-white/60 leading-relaxed">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>

    <div class="text-center" data-anim="fade-up" style="transition-delay: 600ms">
      <a
        href="#contact"
        class="inline-block px-8 py-3.5 bg-accent text-[#141414] rounded-lg font-semibold text-[0.95rem] border-2 border-accent hover:bg-accent-hover hover:border-accent-hover hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(200,117,51,0.35)] transition-all duration-250 cta-pulse"
      >
        Start Your Engine
      </a>
    </div>
  </div>
</section>
