---
import LucideIcon from './LucideIcon';

const stats = [
  { value: 500, suffix: '+', label: 'Clients Served' },
  { value: 98, suffix: '%', label: 'Client Retention' },
  { value: 24, suffix: 'hr', label: 'Response Time' },
  { value: 15, suffix: '+', label: 'Years Experience' },
];

const results = [
  {
    icon: 'BarChart3' as const,
    title: 'Clarity at a Glance',
    description:
      'Know exactly where you stand financially every month. No surprises. No confusion. Just clean, accurate reporting that drives better decisions.',
  },
  {
    icon: 'Clock' as const,
    title: 'More Time for Growth',
    description:
      'Stop worrying about payroll, invoicing, and tax compliance. Focus on what you do best: running your business and serving your clients.',
  },
  {
    icon: 'TrendingUp' as const,
    title: 'Scalable Infrastructure',
    description:
      'Whether you\u2019re one location or twenty, our systems and processes scale with you. No growing pains. Just reliable financial operations.',
  },
  {
    icon: 'Handshake' as const,
    title: 'Built on Trust',
    description:
      'We\u2019re not just vendors\u2014we\u2019re partners invested in your success. Open communication, honest advice, and long-term commitment to your growth.',
  },
];
---

<section class="py-20 px-6 bg-page-bg border-t border-white/[0.05]" id="results">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-14">
      <p
        class="uppercase text-xs font-bold tracking-[3px] text-accent mb-3"
        data-anim="fade-up"
      >
        Results
      </p>
      <h2
        class="text-[1.85rem] md:text-[3rem] font-bold text-white mb-4 leading-tight tracking-tight font-serif"
        data-anim="fade-up"
        style="transition-delay: 100ms"
      >
        What You Get
      </h2>
      <div class="w-16 h-[3px] bg-accent mx-auto mb-4 divider-animate"></div>
    </div>

    <!-- Animated Counters -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-14">
      {
        stats.map((stat, i) => (
          <div
            class="text-center py-6 px-4 rounded-xl bg-card-bg border border-card-border"
            data-anim="scale-in"
            style={`transition-delay: ${i * 100}ms`}
          >
            <div class="text-3xl md:text-4xl font-extrabold text-accent mb-1 font-sans">
              <span
                class="counter-value"
                data-count={stat.value}
                data-suffix={stat.suffix}
              >
                0{stat.suffix}
              </span>
            </div>
            <div class="text-sm text-white/50 font-medium uppercase tracking-wider">
              {stat.label}
            </div>
          </div>
        ))
      }
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-4 gap-6"
      data-stagger
    >
      {
        results.map((result) => (
          <div
            class="text-center p-9 px-6 rounded-xl bg-card-bg border border-card-border transition-all duration-300 hover:border-accent/50 hover:-translate-y-1 hover:shadow-[0_4px_20px_rgba(200,117,51,0.1)] card-glow"
            data-anim="fade-up"
          >
            <div class="w-[60px] h-[60px] bg-accent/15 rounded-[14px] flex items-center justify-center mx-auto mb-4">
              <LucideIcon
                name={result.icon}
                size={28}
                className="text-accent"
              />
            </div>
            <h3 class="text-lg font-bold text-white mb-2.5 font-serif">
              {result.title}
            </h3>
            <p class="text-[0.95rem] text-white/60 leading-relaxed">
              {result.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
