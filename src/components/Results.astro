---
import LucideIcon from './LucideIcon';

const results = [
  {
    icon: 'BarChart3' as const,
    title: 'Financial Clarity',
    description:
      'Clean, accurate financials delivered on schedule. Month-end close, reporting packages, and dashboards that give you a clear picture of where the business stands.',
  },
  {
    icon: 'Clock' as const,
    title: 'Operational Bandwidth',
    description:
      'Payroll, invoicing, tax compliance, and vendor management handled completely. Your leadership team focuses on revenue and operations, not back-office fires.',
  },
  {
    icon: 'TrendingUp' as const,
    title: 'Scalable Infrastructure',
    description:
      'Systems and processes built to handle growth. One location or twenty — the financial infrastructure scales without adding headcount or complexity.',
  },
  {
    icon: 'Handshake' as const,
    title: 'Direct Access',
    description:
      'No ticketing systems. No account managers relaying messages. You work directly with the team running your books. Questions get answered the same day.',
  },
];
---

<section class="py-20 px-6 bg-page-bg border-t border-white/[0.05]" id="results">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-14">
      <p
        class="uppercase text-xs font-bold tracking-[3px] text-accent mb-3"
        data-anim="fade-up"
      >
        Results
      </p>
      <h2
        class="text-[1.85rem] md:text-[3rem] font-bold text-white mb-4 leading-tight tracking-tight font-serif"
        data-anim="fade-up"
        style="transition-delay: 100ms"
      >
        What You Get
      </h2>
      <div class="w-16 h-[3px] bg-accent mx-auto mb-4 divider-animate"></div>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-4 gap-6"
      data-stagger
    >
      {
        results.map((result) => (
          <div
            class="text-center p-9 px-6 rounded-xl bg-card-bg border border-card-border transition-all duration-300 hover:border-accent/50 hover:-translate-y-1 hover:shadow-[0_4px_20px_rgba(200,117,51,0.1)] card-glow"
            data-anim="fade-up"
          >
            <div class="w-[60px] h-[60px] bg-accent/15 rounded-[14px] flex items-center justify-center mx-auto mb-4">
              <LucideIcon
                name={result.icon}
                size={28}
                className="text-accent"
              />
            </div>
            <h3 class="text-lg font-bold text-white mb-2.5 font-serif">
              {result.title}
            </h3>
            <p class="text-[0.95rem] text-white/60 leading-relaxed">
              {result.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
