---
import LucideIcon from './LucideIcon';

const results = [
  {
    icon: 'BarChart3' as const,
    title: 'Clarity at a Glance',
    description:
      'Know exactly where you stand financially every month. No surprises. No confusion. Just clean, accurate reporting that drives better decisions.',
  },
  {
    icon: 'Clock' as const,
    title: 'More Time for Growth',
    description:
      'Stop worrying about payroll, invoicing, and tax compliance. Focus on what you do best: running your business and serving your clients.',
  },
  {
    icon: 'TrendingUp' as const,
    title: 'Scalable Infrastructure',
    description:
      'Whether you\u2019re one location or twenty, our systems and processes scale with you. No growing pains. Just reliable financial operations.',
  },
  {
    icon: 'Handshake' as const,
    title: 'Built on Trust',
    description:
      'We\u2019re not just vendors\u2014we\u2019re partners invested in your success. Open communication, honest advice, and long-term commitment to your growth.',
  },
];
---

<section class="py-24 px-6 bg-off-white" id="results">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-14">
      <p class="uppercase text-xs font-bold tracking-[3px] text-accent mb-3">
        Results
      </p>
      <h2
        class="text-[1.85rem] md:text-[2.5rem] font-extrabold text-slate-900 mb-4 leading-tight tracking-tight"
      >
        What You Get
      </h2>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6"
    >
      {
        results.map((result) => (
          <div class="text-center p-9 px-6 rounded-xl bg-white border border-slate-200 transition-all duration-250 hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)] hover:-translate-y-0.5">
            <div class="w-[60px] h-[60px] bg-accent-light rounded-[14px] flex items-center justify-center mx-auto mb-4">
              <LucideIcon
                name={result.icon}
                size={28}
                className="text-accent"
              />
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2.5">
              {result.title}
            </h3>
            <p class="text-sm text-slate-400 leading-relaxed">
              {result.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
