---
---

<section class="pt-[150px] pb-16 px-6 bg-page-bg relative overflow-hidden">
  <div
    class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-[60px] items-center relative"
  >
    <div class="text-center lg:text-left">
      <p
        class="uppercase text-xs font-bold tracking-[3px] text-accent mb-4"
        data-anim="fade-up"
      >
        Financial Operations for Service-Based Businesses
      </p>
      <h1
        class="text-[2.2rem] md:text-[3.75rem] font-bold leading-[1.25] mb-6 tracking-tight font-serif hero-shimmer"
        data-anim="fade-up"
        style="transition-delay: 150ms"
      >
        The Engine Room Financial Group
      </h1>
      <div class="w-16 h-[3px] bg-accent mb-6 mx-auto lg:mx-0 divider-animate"></div>
      <p
        class="text-xl text-white/60 leading-relaxed mb-9 max-w-[500px] mx-auto lg:mx-0"
        data-anim="fade-up"
        style="transition-delay: 300ms"
      >
        We run your finance department. AP, AR, payroll, reporting, tax compliance — everything that keeps your operation moving, handled with precision.
      </p>
      <div
        class="flex gap-4 flex-wrap justify-center lg:justify-start"
        data-anim="fade-up"
        style="transition-delay: 450ms"
      >
        <a
          href="#contact"
          class="inline-block px-8 py-3.5 bg-accent text-[#141414] rounded-lg font-semibold text-[0.95rem] border-2 border-accent hover:bg-accent-hover hover:border-accent-hover hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(200,117,51,0.35)] transition-all duration-250 cta-pulse"
        >
          Talk to an Operator
        </a>
        <a
          href="#services"
          class="inline-block px-8 py-3.5 bg-transparent text-accent rounded-lg font-semibold text-[0.95rem] border-2 border-accent hover:bg-accent hover:text-white hover:-translate-y-px transition-all duration-250"
        >
          View Services
        </a>
      </div>
    </div>

    <div
      class="flex items-center justify-center lg:order-last"
      data-anim="scale-in"
      style="transition-delay: 300ms"
    >
      <img
        src="https://cdn.b12.io/client_media/aiIZype9/5083136d-1bcf-11f1-838b-0242ac110002-D_HJ7DGkmU52sorSbVY2m.jpg"
        alt="Financial Operations Visualization"
        class="w-full rounded-2xl shadow-[0_8px_30px_rgba(0,0,0,0.3)] hero-float"
        loading="eager"
      />
    </div>
  </div>
</section>
