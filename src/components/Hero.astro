---
---

<section class="pt-[150px] pb-[100px] px-6 bg-gradient-to-br from-white via-off-white to-accent-light relative overflow-hidden">
  <!-- Decorative radial gradient -->
  <div
    class="absolute -top-1/2 -right-1/5 w-[700px] h-[700px] rounded-full"
    style="background: radial-gradient(circle, rgba(59,130,246,0.06) 0%, transparent 70%);"
  >
  </div>

  <div
    class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-[60px] items-center relative"
  >
    <div class="text-center md:text-left">
      <h1
        class="text-[2.2rem] md:text-[3.2rem] font-extrabold text-slate-900 leading-[1.12] mb-6 tracking-tight"
      >
        The Financial Backbone for Service-Based Businesses
      </h1>
      <p
        class="text-lg text-slate-400 leading-relaxed mb-9 max-w-[500px] mx-auto md:mx-0"
      >
        A full-service outsourced financial operations company. Your outsourced
        finance department, strategic back-office partner, and financial
        operating system for service businesses.
      </p>
      <div class="flex gap-4 flex-wrap justify-center md:justify-start">
        <a
          href="#contact"
          class="inline-block px-8 py-3.5 bg-accent text-white rounded-lg font-semibold text-[0.95rem] border-2 border-accent hover:bg-accent-hover hover:border-accent-hover hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(59,130,246,0.35)] transition-all duration-250"
        >
          Talk to an Operator
        </a>
        <a
          href="#services"
          class="inline-block px-8 py-3.5 bg-transparent text-primary rounded-lg font-semibold text-[0.95rem] border-2 border-primary hover:bg-primary hover:text-white hover:-translate-y-px transition-all duration-250"
        >
          View Services
        </a>
      </div>
    </div>

    <div class="flex items-center justify-center order-first md:order-last">
      <img
        src="https://cdn.b12.io/client_media/aiIZype9/5083136d-1bcf-11f1-838b-0242ac110002-D_HJ7DGkmU52sorSbVY2m.jpg"
        alt="Financial Operations Visualization"
        class="w-full rounded-2xl shadow-[0_8px_30px_rgba(0,0,0,0.12)]"
        loading="eager"
      />
    </div>
  </div>
</section>
