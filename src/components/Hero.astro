<section class="pt-[200px] pb-28 px-6 bg-[#141C2B]">
  <div class="max-w-[800px] mx-auto text-center">
    <p
      class="uppercase text-xs font-bold tracking-[3px] text-[#B8943F] mb-6"
      data-anim="fade-up"
    >
      Financial Operations for Service-Based Businesses
    </p>
    <h1
      class="text-[2.5rem] md:text-[4rem] font-bold leading-[1.15] mb-6 tracking-tight font-serif text-white"
      data-anim="fade-up"
      style="transition-delay: 150ms"
    >
      The Engine Room Financial Group
    </h1>
    <div class="w-16 h-[3px] bg-[#B8943F] mb-8 mx-auto divider-animate"></div>
    <p
      class="text-xl text-white/60 leading-relaxed mb-10 max-w-[600px] mx-auto"
      data-anim="fade-up"
      style="transition-delay: 300ms"
    >
      We run your finance department. AP, AR, payroll, reporting, tax compliance — everything that keeps your operation moving, handled with precision.
    </p>
    <div
      data-anim="fade-up"
      style="transition-delay: 450ms"
    >
      <a
        href="#contact"
        class="inline-block px-10 py-4 bg-[#B8943F] text-white rounded-lg font-semibold text-base border-2 border-[#B8943F] hover:bg-[#C9A44E] hover:border-[#C9A44E] hover:-translate-y-px hover:shadow-[0_4px_16px_rgba(184,148,63,0.35)] transition-all duration-250"
      >
        Talk to an Operator
      </a>
    </div>
  </div>
</section>
