---
import MobileMenu from './MobileMenu';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 bg-[#141C2B] border-b border-white/[0.08] z-[1000] px-6 transition-shadow duration-300"
>
  <div class="max-w-[1400px] mx-auto flex items-center justify-between h-[140px]">
    <a href="#" class="flex items-center overflow-hidden h-[120px]">
      <img
        src="/images/TEG_Logo_Updated.png"
        alt="Engine Room Financial Group"
        class="h-[245px] w-auto object-contain"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-7">
      <a
        href="#services"
        class="text-base font-medium text-white/70 hover:text-white relative transition-colors duration-200 nav-link"
        >Services</a
      >
      <a
        href="#industries"
        class="text-base font-medium text-white/70 hover:text-white relative transition-colors duration-200 nav-link"
        >Who We Serve</a
      >
      <a
        href="#methodology"
        class="text-base font-medium text-white/70 hover:text-white relative transition-colors duration-200 nav-link"
        >How We Work</a
      >
      <a
        href="#contact"
        class="text-base font-medium text-white/70 hover:text-white relative transition-colors duration-200 nav-link"
        >Contact</a
      >
      <a
        href="#contact"
        class="inline-block px-6 py-2.5 bg-[#B8943F] text-white rounded-lg font-semibold text-[0.95rem] border-2 border-[#B8943F] hover:bg-[#C9A44E] hover:border-[#C9A44E] hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(184,148,63,0.35)] transition-all duration-250"
        >Get In Touch</a
      >
    </nav>

    <!-- Mobile Menu (React component for interactivity) -->
    <MobileMenu client:load />
  </div>
</header>

<style>
  .nav-link:hover::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: #B8943F;
    border-radius: 1px;
  }
</style>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 10) {
        header.style.boxShadow = '0 2px 12px rgba(0,0,0,0.15)';
      } else {
        header.style.boxShadow = 'none';
      }
    });
  }
</script>
