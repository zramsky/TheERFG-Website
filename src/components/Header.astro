---
import MobileMenu from './MobileMenu';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 bg-[#141414]/97 backdrop-blur-lg border-b border-white/[0.08] z-[1000] px-6 transition-shadow duration-300"
>
  <div class="max-w-[1200px] mx-auto flex items-center justify-between h-[90px]">
    <a href="#" class="flex items-center">
      <img
        src="https://cdn.b12.io/client_media/aiIZype9/11c36e8d-1bd0-11f1-87a5-0242ac110002-TEG_Logo.V6.png"
        alt="Engine Room Financial Group"
        class="h-[100px] w-auto"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-7">
      <a
        href="#services"
        class="text-sm font-medium text-white/60 hover:text-accent relative transition-colors duration-200 nav-link"
        >Services</a
      >
      <a
        href="#industries"
        class="text-sm font-medium text-white/60 hover:text-accent relative transition-colors duration-200 nav-link"
        >Who We Serve</a
      >
      <a
        href="#methodology"
        class="text-sm font-medium text-white/60 hover:text-accent relative transition-colors duration-200 nav-link"
        >How We Work</a
      >
      <a
        href="#results"
        class="text-sm font-medium text-white/60 hover:text-accent relative transition-colors duration-200 nav-link"
        >Results</a
      >
      <a
        href="#contact"
        class="text-sm font-medium text-white/60 hover:text-accent relative transition-colors duration-200 nav-link"
        >Contact</a
      >
      <a
        href="#contact"
        class="inline-block px-6 py-2.5 bg-accent text-white rounded-lg font-semibold text-[0.85rem] border-2 border-accent hover:bg-accent-hover hover:border-accent-hover hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(200,117,51,0.35)] transition-all duration-250"
        >Schedule a Call</a
      >
    </nav>

    <!-- Mobile Menu (React component for interactivity) -->
    <MobileMenu client:load />
  </div>
</header>

<style>
  .nav-link:hover::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }
</style>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 10) {
        header.style.boxShadow = '0 2px 12px rgba(0,0,0,0.3)';
      } else {
        header.style.boxShadow = 'none';
      }
    });
  }
</script>
