---
import LucideIcon from './LucideIcon';

const differentiators = [
  {
    icon: 'Settings' as const,
    title: 'Operator-Run',
    description:
      'We are operators who build and run financial infrastructure. Not consultants. Not advisors. We do the work, every day, alongside your team.',
  },
  {
    icon: 'Crosshair' as const,
    title: 'Industry-Specific',
    description:
      'Our processes are built around the billing cycles, compliance requirements, and operational patterns of the industries we serve. No generic playbooks.',
  },
  {
    icon: 'Shield' as const,
    title: 'Single Point of Accountability',
    description:
      'One team owns your entire financial operation. AP, AR, payroll, reporting — all under one roof with direct access to the people doing the work.',
  },
];
---

<section class="py-20 px-6 bg-[#1a1a1a]" id="testimonials">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-14">
      <p
        class="uppercase text-xs font-bold tracking-[3px] text-accent mb-3"
        data-anim="fade-up"
      >
        Why Us
      </p>
      <h2
        class="text-[1.85rem] md:text-[3rem] font-bold text-white mb-4 leading-tight tracking-tight font-serif"
        data-anim="fade-up"
        style="transition-delay: 100ms"
      >
        What Sets Us Apart
      </h2>
      <div class="w-16 h-[3px] bg-accent mx-auto mb-4 divider-animate"></div>
      <p
        class="text-xl text-white/60 max-w-[640px] mx-auto leading-relaxed"
        data-anim="fade-up"
        style="transition-delay: 200ms"
      >
        Three principles that define how we operate.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6" data-stagger>
      {
        differentiators.map((d) => (
          <div
            class="bg-card-bg rounded-xl p-9 border border-card-border transition-all duration-300 hover:border-accent/50 hover:shadow-[0_4px_20px_rgba(200,117,51,0.1)] card-glow card-tilt"
            data-anim="fade-up"
          >
            <div class="w-[60px] h-[60px] bg-accent/15 rounded-[14px] flex items-center justify-center mb-4">
              <LucideIcon
                name={d.icon}
                size={28}
                className="text-accent"
              />
            </div>
            <h3 class="text-lg font-bold text-white mb-2.5 font-serif">
              {d.title}
            </h3>
            <p class="text-[0.95rem] text-white/60 leading-relaxed">
              {d.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
